# Formspree for admin order notifications
# Get your endpoint from: https://formspree.io
FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID

# Resend for customer confirmation emails
# Get your API key from: https://resend.com (free tier available)
RESEND_API_KEY=re_xxx_your_api_key_here

# From email address for customer confirmations and admin notifications.
# Must be a verified sender in Resend.
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Where you want to receive admin order notifications.
ORDER_NOTIFICATION_EMAIL=you@example.com
